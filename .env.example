# ─── DATABASE ───────────────────────────────────────────
DB_USER=timuser
DB_PASS=timpass
DB_NAME=tripinminutes
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL="postgresql://timuser:timpass@localhost:5432/tripinminutes?schema=public"

# ─── REDIS ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=redispass
REDIS_URL="redis://:redispass@localhost:6379"

# ─── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_token_min_32_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_token_min_32_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── SERVER ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── EMAIL (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@tripinminutes.com
SUPPORT_EMAIL=support@tripinminutes.com

# ─── CLOUDINARY (File Uploads) ───────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── RAZORPAY (Payments) ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── RATE LIMITING ───────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── pgAdmin ─────────────────────────────────────────────
PGADMIN_EMAIL=admin@tripinminutes.com
PGADMIN_PASS=pgadmin123
